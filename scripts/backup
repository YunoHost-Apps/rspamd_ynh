#!/bin/bash

source /usr/share/yunohost/helpers

#=================================================
# BACKUP SYSTEM CONFIGURATION
#=================================================

ynh_backup "/usr/share/yunohost/hooks/conf_regen/99-postfix_rspamd"
ynh_backup "/etc/dovecot/global_script/rspamd.sieve"
ynh_backup "/etc/dovecot/yunohost.d/post-ext.d/antispam.conf"
ynh_backup "/usr/lib/dovecot/sieve/report-spam.sieve"
ynh_backup "/usr/lib/dovecot/sieve/report-ham.sieve"
ynh_backup "/usr/lib/dovecot/sieve/rspamd-learn-spam.sh"
ynh_backup "/usr/lib/dovecot/sieve/rspamd-learn-ham.sh"

ynh_backup "/etc/rspamd"

# logrotate config may not exist if it was never enabled
if [ -f "/etc/logrotate.d/$app" ]; then
    ynh_backup "/etc/logrotate.d/$app"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will then actually copy those files to the archive)."
